# ============================================
# 2D 轉 3D 模型專案 - .gitignore
# ============================================

# --------------------------------------------
# 上傳目錄：使用者上傳的作品不納入版本控制
# --------------------------------------------
# 理由：uploads/ 內為執行時產生的 STL / SVG / JSON，每台機器、每個環境
#       會不同，且體積可能變大。程式碼已能自動建立此資料夾，無需追蹤內容。
uploads/

# --------------------------------------------
# Windows 系統與編輯器產生的檔案
# --------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
*.lnk

# VS Code
.vscode/
*.code-workspace

# Cursor
.cursor/

# 暫存 / 備份
*.tmp
*.temp
*.bak
*~
*.swp
*.swo

# --------------------------------------------
# PHP / 開發環境（若未來有使用）
# --------------------------------------------
# Composer
/vendor/

# 環境變數或機密設定（若有 .env 請勿提交）
.env
.env.local
.env.*.local

# --------------------------------------------
# 日誌與除錯輸出（若有）
# --------------------------------------------
*.log
logs/
